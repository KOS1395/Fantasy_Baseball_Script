# ── Gmail SMTP credentials ──────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Enable at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Email addresses ──────────────────────────────────────────────────────────
EMAIL_FROM=your_gmail_address@gmail.com
# Comma-separated if you want multiple recipients
EMAIL_TO=recipient@example.com

# ── Scheduler (Wednesday=2, Sunday=6  — cron day_of_week values) ─────────────
# Defaults already set to Wed & Sun at 7:00 PM Eastern.
# Change the hour to your preferred local time.
SCHEDULE_DAYS=wed,sun
SCHEDULE_HOUR=19
SCHEDULE_MINUTE=0
